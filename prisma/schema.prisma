// OrderHub — Prisma schema
// PostgreSQL relational model for multi-tenant delivery order management.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}

enum OrderSource {
  TIKTOK
  INSTAGRAM
  WHATSAPP
  WEBSITE
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum Governorate {
  AL_ASIMAH
  HAWALLI
  FARWANIYA
  AHMADI
  MUBARAK_AL_KABEER
  JAHRA
}

enum HousingType {
  HOUSE
  APARTMENT
}

enum PaymentMethod {
  ONLINE
  CASH
}

model User {
  id           String              @id @default(cuid())
  fullName     String
  email        String              @unique
  passwordHash String
  role         Role                @default(EMPLOYEE)
  isActive     Boolean             @default(true)
  resetToken   String?             @unique
  resetTokenExpiry DateTime?
  assignments  ProjectAssignment[]
  orders       Order[]
  activityLogs ActivityLog[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Project {
  id          String              @id @default(cuid())
  name        String
  phone       String?
  website     String?
  instagram   String?
  tiktok      String?
  status      ProjectStatus       @default(ACTIVE)
  assignments ProjectAssignment[]
  orders      Order[]
  activityLogs ActivityLog[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// M:N join between users and projects.
model ProjectAssignment {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Order {
  id          String      @id @default(cuid())
  publicId    String      @unique // used for /invoice/:publicId
  orderNumber String      @unique // ORD-2026-000001
  year        Int

  customerName String
  source       OrderSource
  orderDate    DateTime
  deliveryDate DateTime

  // Address
  governorate    Governorate
  area           String
  block          String
  street         String
  housingType    HousingType
  buildingNumber String
  floor          String?
  apartmentNumber String?

  deliveryFee   Float         @default(0)
  subtotal      Float         @default(0)
  grandTotal    Float         @default(0)
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH)

  items     OrderItem[]

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([createdById])
  @@index([status])
  @@index([year])
}

model OrderItem {
  id          String  @id @default(cuid())
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  productName String
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  @@index([orderId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  detail    String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

// Yearly counter used to generate sequential order numbers safely.
model OrderCounter {
  year    Int @id
  current Int @default(0)
}

// Singleton platform settings (id is always "global").
model Setting {
  id            String @id @default("global")
  currency      String @default("KD")
  timezone      String @default("Asia/Kuwait")
  receiptHeader String?
  receiptFooter String?
  qrSize        Int    @default(220)
  updatedAt     DateTime @updatedAt
}
