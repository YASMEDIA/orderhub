// Mahalatly — Prisma schema
// PostgreSQL relational model for multi-tenant delivery order management.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries use the pooled connection (good for serverless / Neon).
  url       = env("DATABASE_URL")
  // Migrations use a direct (non-pooled) connection. DIRECT_URL is optional:
  // the Vercel build script falls back to Neon's direct URL (DATABASE_URL_UNPOOLED
  // / POSTGRES_URL_NON_POOLING) or to DATABASE_URL when it isn't set by hand.
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
  DRIVER
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}

enum OrderSource {
  TIKTOK
  INSTAGRAM
  WHATSAPP
  WEBSITE
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum Governorate {
  AL_ASIMAH
  HAWALLI
  FARWANIYA
  AHMADI
  MUBARAK_AL_KABEER
  JAHRA
}

enum HousingType {
  HOUSE
  APARTMENT
}

enum PaymentMethod {
  ONLINE
  CASH
}

model User {
  id           String              @id @default(cuid())
  fullName     String
  email        String              @unique
  passwordHash String
  role         Role                @default(EMPLOYEE)
  isActive     Boolean             @default(true)
  resetToken   String?             @unique
  resetTokenExpiry DateTime?
  assignments  ProjectAssignment[]
  orders       Order[]
  activityLogs ActivityLog[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Project {
  id          String              @id @default(cuid())
  name        String
  phone       String?
  website     String?
  instagram   String?
  tiktok      String?
  whatsapp    String?
  status      ProjectStatus       @default(ACTIVE)
  slug         String?            @unique // public storefront URL: /store/:slug
  logoUrl      String?
  storeEnabled Boolean            @default(false)
  showStock    Boolean            @default(true) // show available quantity to customers on the storefront
  assignments ProjectAssignment[]
  orders      Order[]
  products    Product[]
  activityLogs ActivityLog[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// A catalog product belonging to a single project, with quantity-based
// tiered pricing (the more you buy, the lower the unit price).
model Product {
  id          String        @id @default(cuid())
  name        String
  description String?       // shown on the public storefront
  images      String[]      @default([]) // up to 4 product images (data URLs or https)
  basePrice  Float         @default(0) // unit price for quantity >= 1
  isActive   Boolean       @default(true)
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  tiers      ProductTier[]
  variants   ProductVariant[]
  orderItems OrderItem[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([projectId])
}

// A selectable variant of a product (e.g. a colour), with its own independent
// stock and images. Tier pricing is based on the TOTAL quantity across all of a
// product's variants, not per-variant — see lib/pricing.ts.
model ProductVariant {
  id         String                @id @default(cuid())
  product    Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  name       String                // e.g. "Black"
  colorHex   String                @default("#000000") // swatch colour
  sku        String?               // optional stock-keeping unit
  stock      Int                   @default(0) // independent inventory
  isActive   Boolean               @default(true)
  position   Int                   @default(0) // display order
  images     ProductVariantImage[]
  orderItems OrderItem[]
  movements  InventoryMovement[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([productId])
}

// One image belonging to a variant (data URL or https). Multiple per variant.
model ProductVariantImage {
  id        String         @id @default(cuid())
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId String
  url       String
  position  Int            @default(0)

  @@index([variantId])
}

// Audit trail of every stock change for a variant. delta is negative for a sale
// (stock out) and positive for a restock/adjustment.
model InventoryMovement {
  id        String         @id @default(cuid())
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId String
  delta     Int
  reason    String         // "ORDER" | "RESTOCK" | "ADJUSTMENT"
  orderId   String?        // set when caused by an order
  createdAt DateTime       @default(now())

  @@index([variantId])
  @@index([orderId])
}

// "From minQuantity units, unit price becomes unitPrice." e.g. (5, 1.8), (10, 1.7).
model ProductTier {
  id          String  @id @default(cuid())
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  minQuantity Int
  unitPrice   Float

  @@index([productId])
}

// M:N join between users and projects.
model ProjectAssignment {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Order {
  id          String      @id @default(cuid())
  publicId    String      @unique // used for /invoice/:publicId
  orderNumber String      @unique // ORD-2026-000001
  year        Int

  customerName  String
  customerPhone String      @default("")
  source        OrderSource
  orderDate    DateTime
  deliveryDate DateTime

  // Address
  governorate    Governorate
  area           String
  block          String
  street         String
  housingType    HousingType
  buildingNumber String
  floor          String?
  apartmentNumber String?
  locationUrl     String  @default("") // customer's shared map pin / coordinates (optional)

  deliveryFee   Float         @default(0)
  subtotal      Float         @default(0)
  grandTotal    Float         @default(0)
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH)

  items     OrderItem[]

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  // Nullable: orders placed through the public storefront have no internal creator.
  createdBy   User?  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([createdById])
  @@index([status])
  @@index([year])
}

model OrderItem {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId   String?
  productName String
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  // Variant snapshot — kept on the line so invoices stay accurate even if the
  // variant is later renamed or deleted. variantId is nullable (SetNull).
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantId    String?
  variantName  String?
  variantColor String?

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  detail    String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

// Yearly counter used to generate sequential order numbers safely.
model OrderCounter {
  year    Int @id
  current Int @default(0)
}

// Singleton platform settings (id is always "global").
model Setting {
  id            String @id @default("global")
  currency      String @default("KD")
  timezone      String @default("Asia/Kuwait")
  receiptHeader String?
  receiptFooter String?
  qrSize        Int    @default(220)
  updatedAt     DateTime @updatedAt
}
