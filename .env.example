# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orderhub?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Public base URL used to build invoice links + QR codes
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed credentials for the initial Super Admin
SEED_ADMIN_EMAIL="admin@orderhub.com"
SEED_ADMIN_PASSWORD="Admin@12345"
