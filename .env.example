# PostgreSQL connection string.
# On Neon use the POOLED connection string here (good for serverless), with
# ?sslmode=require. For local Postgres, the plain URL is fine.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mahalatly?schema=public"

# Direct (non-pooled) connection used by Prisma migrations. On Neon use the
# DIRECT connection string. For local/single-instance, set it = DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/mahalatly?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Public base URL used to build invoice links + QR codes
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed credentials for the initial Super Admin
SEED_ADMIN_EMAIL="admin@mahalatly.com"
SEED_ADMIN_PASSWORD="Admin@12345"

# Invoice email delivery.
# Preferred: Resend (HTTP API — faster/more reliable than SMTP). Set the key
# and every new order emails its invoice PDF. Get a key at https://resend.com.
RESEND_API_KEY="re_xxxxxxxxx"
# Sender: must be on a domain verified in your Resend account. For quick tests
# without a verified domain, use "onboarding@resend.dev" (delivers only to your
# own Resend account email).
RESEND_FROM="Mahalatly <info@mahalatly.com>"
#
# Fallback: SMTP (used only when RESEND_API_KEY is unset). Leave all unset to
# disable email entirely (orders still succeed).
# For Gmail, use an App Password (not your normal password):
#   https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASS="your-16-char-app-password"
# From header; defaults to SMTP_USER if unset.
SMTP_FROM="your-gmail-address@gmail.com"
# Where invoices are sent. Defaults to Malyaseri9@gmail.com.
INVOICE_NOTIFY_EMAIL="Malyaseri9@gmail.com"
